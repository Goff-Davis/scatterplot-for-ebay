{
  "manifest_version": 3,
  "name": "eBay Scatterplot",
  "version": "1.0.0",

  "description": "Creates a scatterplot of times and prices of selected eBay listings.",

  "icons": {
    "48": "icons/scatterplot-48.png",
    "96": "icons/scatterplot-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ebay-scatterplot@davisgoff.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.ebay.com/sch/*"],
      "js": [
        "vendor/chart.js/chart.umd.min.js",
        "src/constants.js",
        "src/storage.js",
        "src/extract.js",
        "src/styles.js",
        "src/chart.js",
        "src/dock.js",
        "src/checkboxes.js",
        "src/panel.js",
        "src/init.js"
      ]
    }
  ]
}
